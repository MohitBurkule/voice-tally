# Copy to .env.android (gitignored) and fill in.
# Script reads this file; any value left blank will be prompted at runtime.

# --- App identity ---
APP_ID=co.fruitcast.voicetally
APP_NAME=Voice Tally
APP_VERSION=1.0.0

# --- Signing (optional) ---
# If KEYSTORE_PATH is set, script builds a signed release APK.
# If left blank, script builds an unsigned debug APK (good for sideloading).
#
# Generate a keystore once with:
#   keytool -genkey -v -keystore release.jks -keyalg RSA \
#           -keysize 2048 -validity 10000 -alias voicetally
KEYSTORE_PATH=
KEYSTORE_PASSWORD=
KEY_ALIAS=
KEY_PASSWORD=

# --- Toolchain (only set if non-default) ---
# ANDROID_HOME=/opt/android-sdk
# JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64
